{
    "name": "jsonlines-compare",
    "displayName": "JSONLines Compare",
    "description": "Compare two JSONLines files side-by-side with synchronized navigation and search.",
    "version": "0.0.1",
    "publisher": "local",
    "engines": {
        "vscode": "^1.90.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:jsonlCompare.open"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "jsonlCompare.open",
                "title": "JSONLines Compare: Open Comparison View"
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "dependencies": {
        "monaco-editor": "^0.52.2"
    },
    "devDependencies": {
        "@types/node": "^20.16.5",
        "@types/vscode": "^1.90.0",
        "typescript": "^5.6.2"
    }
}